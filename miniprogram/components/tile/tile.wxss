/* ===================================================================== *
 * 牌：Skyline 不支持 clip-path: polygon —— 用嵌套 view 模拟 P5 切角效果。
 * 思路：
 *   1. 卡片本体是规则矩形（border-radius 给一点弧形，不是直角）
 *   2. 右上角放一个红色小三角（border 三角技巧），是 P5 风格的标志
 *   3. 阴影是另一块 view，斜偏一点
 * ===================================================================== */

.tile {
  position: relative;
  display: inline-block;
  flex-shrink: 0;
  transform: rotate(-2deg);
  animation-name: p5-tile-in;
  animation-duration: 0.45s;
  animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  animation-fill-mode: backwards;
}

/* Skyline 1.4.7 的 aspect-ratio 在 inline-block 容器上不可靠，
   宽高都显式给出来——比例严格保持 80:112 (5:7) */
.tile.size-sm { width: 72rpx; height: 100rpx; }
.tile.size-md { width: 100rpx; height: 140rpx; }
.tile.size-lg { width: 128rpx; height: 180rpx; }

.shadow {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 100%;
  height: 100%;
  background: #0a0a0a;
  z-index: 1;
  border-radius: 6rpx;
  opacity: 0.6;
}

.card {
  position: relative;
  width: 100%;
  height: 100%;
  background: #ece5cf;
  border: 4rpx solid #0a0a0a;
  border-radius: 6rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.tile.color-black .card {
  background: #0a0a0a;
}

/* 红色三角"切角"标志：用 border 三角技巧（不需要 clip-path）。
 * 把它放在 card 内部的右上角，看起来就是这张牌"被切了一个角"的视觉。 */
.corner {
  position: absolute;
  top: 0;
  right: 0;
  width: 0;
  height: 0;
  border-top: 30rpx solid #e60022;
  border-left: 30rpx solid transparent;
  z-index: 3;
}

.rule-line {
  position: absolute;
  top: 18%;
  left: 12%;
  right: 18%;
  height: 2rpx;
  background: rgba(10,10,10,0.18);
  z-index: 3;
}
.tile.color-black .rule-line {
  background: rgba(250,250,243,0.16);
}

.halftone-row {
  position: absolute;
  bottom: 8%;
  left: 10%;
  display: flex;
  flex-direction: row;
  align-items: center;
  z-index: 3;
}
.halftone-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(230,0,34,0.95);
  margin-right: 6rpx;
}

.glyph {
  position: absolute;
  top: 50%;
  left: 50%;
  font-style: italic;
  font-weight: 700;
  font-family: 'Impact', 'Bebas Neue', 'Oswald', sans-serif;
  letter-spacing: -0.02em;
  z-index: 4;
  line-height: 1;
}

.tile.size-sm .glyph { font-size: 56rpx; }
.tile.size-md .glyph { font-size: 78rpx; }
.tile.size-lg .glyph { font-size: 102rpx; }

.glyph.number {
  color: #0a0a0a;
  transform: translate(-50%, -50%);
}
.tile.color-black .glyph.number { color: #fafaf3; }

.glyph.qmark {
  color: #e60022;
  transform: translate(-50%, -50%);
}
.glyph.qmark-shadow {
  color: rgba(10,10,10,0.18);
  transform: translate(-58%, -55%);
}
.tile.color-black .glyph.qmark-shadow {
  color: rgba(250,250,243,0.18);
}

.glyph.star {
  color: #0a0a0a;
  transform: translate(-50%, -50%);
}
.tile.color-black .glyph.star { color: #fafaf3; }
.glyph.star-shadow {
  color: #e60022;
  transform: translate(-46%, -45%);
}

.corner-spark {
  position: absolute;
  font-size: 18rpx;
  color: #e60022;
  z-index: 5;
}
.corner-spark.a { top: 28%; left: 12%; }
.corner-spark.b { bottom: 18%; right: 12%; }

/* 暂置牌悬浮 */
.tile.is-pending {
  animation:
    p5-tile-in 0.45s cubic-bezier(0.16, 1, 0.3, 1) backwards,
    p5-pending-hover 1.6s ease-in-out 0.5s infinite;
}
.tag.pending-tag {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%) skewX(-10deg);
  background: #e60022;
  padding: 4rpx 14rpx;
  border: 3rpx solid #0a0a0a;
  z-index: 6;
}
.tag.pending-tag text {
  color: #fafaf3;
  font-size: 18rpx;
  letter-spacing: 0.16em;
  font-weight: 700;
}

.tag.exposed-tag {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%) skewX(-10deg);
  background: #fafaf3;
  padding: 4rpx 14rpx;
  border: 3rpx solid #0a0a0a;
  box-shadow: 4rpx 4rpx 0 #e60022;
  z-index: 6;
}
.tag.exposed-tag text {
  color: #0a0a0a;
  font-size: 18rpx;
  letter-spacing: 0.16em;
  font-weight: 700;
}

.exposed-slash {
  position: absolute;
  top: 50%;
  left: -6%;
  right: -6%;
  height: 4rpx;
  background: #e60022;
  transform: translateY(-50%) rotate(-12deg);
  z-index: 5;
  opacity: 0.55;
}

.hidden-dot {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e60022;
  z-index: 5;
  animation: p5-blink 1.5s ease-in-out infinite;
}

.tile.is-owned-hidden { opacity: 0.92; }
.tile.is-owned-exposed { opacity: 0.6; }

.tile.is-pulse {
  animation:
    p5-tile-in 0.45s cubic-bezier(0.16, 1, 0.3, 1) backwards,
    p5-selectable-pulse 0.9s ease-in-out infinite;
}

.tile.is-selected {
  transform: rotate(-1deg) translateY(-28rpx) scale(1.06);
  z-index: 10;
}

/* hover-class 取代 :active —— Skyline 不支持 :active 伪类 */
.tile-tap-press {
  transform: rotate(-1deg) translateY(-12rpx) scale(0.97);
}

.tile.flash-correct {
  animation: p5-flash-correct 1s ease-out;
}
.tile.flash-wrong {
  animation: p5-flash-wrong 0.7s ease-out;
}
