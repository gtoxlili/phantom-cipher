<view wx:if="{{visible}}" class="backdrop" bind:tap="onClose">
  <view class="sheet" catch:tap="onSheetTap">
    <view class="title">
      <text class="strong">{{targetName}}</text>
      <text class="hint">第 {{position + 1}} 张</text>
      <view class="color-tag color-{{color}}">
        <text>{{color === 'black' ? '黑' : '白'}}</text>
      </view>
    </view>

    <view class="num-grid">
      <view
        class="num-btn"
        wx:for="{{nums}}"
        wx:key="*this"
        wx:for-item="n"
        wx:for-index="i"
        data-n="{{n}}"
        bind:tap="onPick"
        style="animation-delay: {{i * 30 + 80}}ms"
      >
        <text>{{n}}</text>
      </view>
    </view>

    <view class="joker-btn" bind:tap="onJoker">
      <view class="joker-row">
        <text class="star">★</text>
        <text class="label">JOKER</text>
        <text class="zh">赖子</text>
      </view>
    </view>

    <view class="cancel" bind:tap="onClose">
      <text>CANCEL ✕</text>
    </view>
  </view>
</view>
