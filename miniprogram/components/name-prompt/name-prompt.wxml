<view class="np-main">
  <sketch />
  <view class="card">
    <text class="eyebrow">· ROOM · {{code}} ·</text>
    <text class="heading">取一个代号</text>
    <text class="lead">朋友邀你入局，先告诉大家你的称呼。</text>
    <input
      class="input"
      value="{{draft}}"
      placeholder="JOKER"
      maxlength="16"
      placeholder-style="color: rgba(10,10,10,0.4); font-style: italic;"
      bindinput="onInput"
      confirm-type="done"
      bindconfirm="onSubmit"
    />
    <view class="shuffle" bind:tap="onShuffle">
      <text class="spark">✦</text>
      <text>随机代号 / SHUFFLE</text>
      <text class="spark">✦</text>
    </view>
    <view class="submit {{!draft || !draft.trim() ? 'disabled' : ''}}" bind:tap="onSubmit">
      <text>入局 ▶</text>
    </view>
    <view class="link" bind:tap="onCancel">
      <text>‹ BACK TO LOBBY</text>
    </view>
  </view>
</view>
