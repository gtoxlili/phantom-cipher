/* ===================================================================== *
 * Header 两行布局：
 *   Row 1 (hd-primary)  back-btn + cipher-key-card —— 高度严格按胶囊
 *                       高度排，视觉跟系统胶囊同行同高对齐
 *   Row 2 (hd-secondary) 断线提示（左）+ 日志按钮（右）—— 不再受
 *                       capsule-safe-right 限制，全宽可用
 * ===================================================================== */

.hd {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
}

/* Row 1 —— 跟胶囊同高同行 */
.hd-primary {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 24rpx;
  /* padding-right + min-height 由 inline style 注入 = 胶囊高度 */
}

/* Row 2 —— 全宽，右下角放日志按钮 */
.hd-secondary {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx 0;
}
.hd-spacer { flex: 1; }

/* ====== 按钮 ====== */
.icon-btn {
  /* width / height 在 inline style 里给（Row 1 跟胶囊等高）；
     log-btn 在 Row 2 用单独的固定尺寸 */
  border: 3rpx solid #fafaf3;
  background: #131313;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: skewX(-6deg);
  box-shadow: 4rpx 4rpx 0 #e60022;
}
.icon-btn-press {
  transform: skewX(-6deg) translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #e60022;
}

/* Row 2 的日志按钮单独尺寸，比 Row 1 略小一圈，跟 Row 2 整体克制调性匹配 */
.log-btn {
  width: 60rpx;
  height: 60rpx;
}

/* ====== Cipher key card ====== */
.code-wrap {
  flex: 1;
  margin-left: 14rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafaf3;
  border: 3rpx solid #0a0a0a;
  box-shadow: 5rpx 5rpx 0 #e60022;
  padding: 0 16rpx;
  transform: skewX(-8deg);
  /* min-height 由 inline style 注入 = 胶囊高度，跟左侧 back 按钮等高 */
}
.code-wrap-press {
  box-shadow: 2rpx 2rpx 0 #e60022;
  transform: skewX(-8deg) translate(3rpx, 3rpx);
}

.label {
  display: inline-block;
  transform: skewX(8deg);
  color: #e60022;
  font-size: 16rpx;
  letter-spacing: 0.28em;
  font-weight: 700;
  font-style: italic;
  white-space: nowrap;
  line-height: 1;
}

.code {
  display: inline-block;
  transform: skewX(8deg);
  color: #0a0a0a;
  font-size: 32rpx;
  font-weight: 900;
  font-style: italic;
  letter-spacing: 0.16em;
  line-height: 1.05;
  margin: 1rpx 0;
  white-space: nowrap;
}

.copy-hint {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  transform: skewX(8deg);
  color: rgba(10,10,10,0.6);
  font-size: 14rpx;
  letter-spacing: 0.22em;
  font-weight: 700;
  line-height: 1;
}
.copy-hint icon { margin-left: 4rpx; }
.copy-hint text {
  color: rgba(10,10,10,0.6);
  font-size: 14rpx;
  letter-spacing: 0.22em;
  font-weight: 700;
  white-space: nowrap;
}

/* ====== 断线提示 chip ====== */
.disconnected {
  background: #e60022;
  color: #fafaf3;
  border: 3rpx solid #0a0a0a;
  padding: 4rpx 14rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  transform: skewX(-6deg);
}
.disconnected .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fafaf3;
  margin-right: 8rpx;
  animation: p5-blink 1s ease-in-out infinite;
}
.disconnected text {
  display: inline-block;
  transform: skewX(6deg);
  color: #fafaf3;
  font-size: 18rpx;
  letter-spacing: 0.22em;
  font-weight: 700;
  white-space: nowrap;
}
