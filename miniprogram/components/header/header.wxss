/* ===================================================================== *
 * Header Row 1：back-btn + cipher-key-card
 * 严格按胶囊高度排，整行视觉跟系统胶囊同行同高。
 * ===================================================================== */

.hd {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 24rpx;
  /* padding-right + min-height 由 inline style 注入 = 胶囊高度 */
}

/* ====== 按钮 ====== */
.icon-btn {
  border: 3rpx solid #fafaf3;
  background: #131313;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: skewX(-6deg);
  box-shadow: 4rpx 4rpx 0 #e60022;
}
.icon-btn-press {
  transform: skewX(-6deg) translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #e60022;
}

/* ====== Cipher key card ======
 * 内部排版：上面 eyebrow 一行（左 label "CIPHER KEY //" + 右 hint
 * "TAP TO COPY"），下面主体大字号房间码。
 * eyebrow 横排把空间用足，code 拿走垂直主轴的视觉权重。 */
.code-wrap {
  flex: 1;
  margin-left: 14rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #fafaf3;
  border: 3rpx solid #0a0a0a;
  box-shadow: 5rpx 5rpx 0 #e60022;
  padding: 0 14rpx;
  transform: skewX(-8deg);
}
.code-wrap-press {
  box-shadow: 2rpx 2rpx 0 #e60022;
  transform: skewX(-8deg) translate(3rpx, 3rpx);
}

.code-eyebrow {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  transform: skewX(8deg);
  line-height: 1;
}
.lab-l {
  color: #e60022;
  font-size: 14rpx;
  letter-spacing: 0.22em;
  font-weight: 800;
  font-style: italic;
  white-space: nowrap;
}
.lab-r {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
}
.lab-r icon { margin-left: 4rpx; }
.lab-r text {
  color: rgba(10,10,10,0.55);
  font-size: 14rpx;
  letter-spacing: 0.18em;
  font-weight: 700;
  white-space: nowrap;
}

.code {
  display: inline-block;
  transform: skewX(8deg);
  text-align: center;
  color: #0a0a0a;
  font-size: 34rpx;
  font-weight: 900;
  font-style: italic;
  letter-spacing: 0.22em;
  line-height: 1.05;
  white-space: nowrap;
}
