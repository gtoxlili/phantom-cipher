<!-- Row 1：跟系统胶囊视觉同高同行（back + cipher key card），
     胶囊右边占位由 padding-right 让出来。
     第二行 (phase-banner + log button) 由 room.wxml 自行组装 -->
<view
  class="hd"
  style="padding-right: {{capsuleSafeRight}}px; min-height: {{capsuleHeight}}px"
>
  <view
    class="icon-btn"
    hover-class="icon-btn-press"
    hover-stay-time="80"
    bind:tap="onBack"
    style="height: {{capsuleHeight}}px; width: {{capsuleHeight}}px"
  >
    <icon name="chevron-left" size="36" color="#fafaf3" />
  </view>

  <!-- Cipher key 卡：evidence-tag 三段式
       左：红 spine（视觉重音）
       中：label "CIPHER KEY //" 上 + 大字号 code 下
       右：action chip（COPIED ✓ / SHARE ↗） -->
  <view
    class="code-wrap"
    hover-class="code-wrap-press"
    hover-stay-time="80"
    bind:tap="onShare"
    style="min-height: {{capsuleHeight}}px"
  >
    <view class="code-spine" />
    <view class="code-body">
      <text class="code-label">CIPHER KEY //</text>
      <text class="code">{{code}}</text>
    </view>
    <view class="code-aux {{copied ? 'is-copied' : ''}}">
      <icon wx:if="{{copied}}" name="check" size="18" color="#e60022" />
      <icon wx:else name="qr" size="18" color="#0a0a0a" />
      <text>{{copied ? 'COPIED' : 'SHARE'}}</text>
    </view>
  </view>
</view>
