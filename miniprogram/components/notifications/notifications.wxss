.stack {
  position: fixed;
  z-index: 200;
  left: 24rpx;
  right: 24rpx;
  top: 100rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  pointer-events: none;
}

.toast {
  pointer-events: auto;
  position: relative;
  background: #fafaf3;
  color: #0a0a0a;
  border: 3rpx solid #0a0a0a;
  box-shadow: 6rpx 6rpx 0 #e60022;
  padding: 16rpx 22rpx 16rpx 30rpx;
  transform: skewX(-8deg);
  animation: toast-slam 0.3s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  align-self: flex-start;
  max-width: 100%;
}

@keyframes toast-slam {
  0% { opacity: 0; transform: translateX(-120rpx) skewX(-8deg) scale(0.92); }
  60% { opacity: 1; transform: translateX(8rpx) skewX(-8deg) scale(1); }
  100% { opacity: 1; transform: translateX(0) skewX(-8deg) scale(1); }
}

.toast .bar {
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 8rpx;
  background: #e60022;
}

.toast text {
  display: inline-block;
  transform: skewX(8deg);
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #0a0a0a;
  word-break: break-all;
}

.toast-press {
  box-shadow: 2rpx 2rpx 0 #e60022;
  transform: translate(4rpx, 4rpx) skewX(-8deg);
}
