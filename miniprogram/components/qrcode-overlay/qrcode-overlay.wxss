.backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 110;
  background: rgba(10,10,10,0.86);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: p5-fade-in 0.2s ease-out;
}

.sheet {
  width: 86%;
  max-width: 580rpx;
  background: #131313;
  border: 5rpx solid #fafaf3;
  box-shadow: 12rpx 12rpx 0 #e60022;
  padding: 36rpx 32rpx 28rpx;
  transform: skewX(-3deg);
  animation: qr-burst 0.36s cubic-bezier(0.16, 1, 0.3, 1) backwards;
}
/* Skyline 不支持 *（universal selector），把 sheet 内每个直接子项
   反向 skew 抵消父级 skewX(-3deg)，要逐个枚举类名 */
.sheet .eyebrow,
.sheet .frame,
.sheet .caption,
.sheet .dismiss { transform: skewX(3deg); }
/* 本地 keyframe，组件 styleIsolation 下不能可靠用 app.wxss 全局 keyframes */
@keyframes qr-burst {
  0%   { transform: scale(0.5)  rotate(-10deg); opacity: 0; }
  60%  { transform: scale(1.15) rotate(2deg);   opacity: 1; }
  100% { transform: scale(1)    rotate(-3deg);  opacity: 1; }
}

.eyebrow {
  text-align: center;
  margin-bottom: 22rpx;
}
.eyebrow text {
  display: inline-block;
  background: #e60022;
  color: #fafaf3;
  padding: 6rpx 18rpx;
  font-size: 20rpx;
  font-weight: 800;
  font-style: italic;
  letter-spacing: 0.32em;
  border: 2rpx solid #fafaf3;
  transform: skewX(-8deg);
}

/* aspect-ratio 在 Skyline 1.4.7 不可靠，frame 容易塌成 0 高度让 <image>
   渲染不出来 —— 直接给死高宽。sheet 最大宽 580rpx + padding 32rpx*2 +
   frame padding 24rpx*2，剩 ~468rpx 给二维码用，圆整到 460rpx 方框。 */
.frame {
  width: 100%;
  height: 460rpx;
  background: #fafaf3;
  border: 4rpx solid #0a0a0a;
  box-shadow: 6rpx 6rpx 0 #e60022;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22rpx;
}
.qr {
  width: 100%;
  height: 100%;
}

.fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
}
.fallback .big {
  color: #e60022;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1;
}
.fallback .line {
  color: #0a0a0a;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.18em;
  font-style: italic;
}
.fallback .hint {
  color: rgba(10,10,10,0.55);
  font-size: 18rpx;
  letter-spacing: 0.18em;
}

.caption {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 22rpx;
}
.caption .kana {
  color: #ffd200;
  font-size: 22rpx;
  letter-spacing: 0.42em;
  font-weight: 800;
  font-style: italic;
}
.caption .cn {
  color: #ece5cf;
  font-size: 22rpx;
  letter-spacing: 0.18em;
  margin-top: 6rpx;
  font-weight: 700;
}

.dismiss {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
}
.dismiss text {
  color: #fafaf3;
  font-size: 22rpx;
  letter-spacing: 0.32em;
  font-weight: 700;
  white-space: nowrap;
}
.dismiss-press text { color: #e60022; }
