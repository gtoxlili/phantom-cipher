.banner-host {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  pointer-events: none;
}

.banner {
  display: inline-block;
  padding: 10rpx 24rpx;
  border: 3rpx solid #0a0a0a;
  transform: skewX(-9deg);
  animation: p5-streak-in 0.42s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  max-width: 100%;
}

.banner.mood-idle {
  background: #131313;
  color: #ece5cf;
  border-color: rgba(250,250,243,0.4);
  box-shadow: 4rpx 4rpx 0 rgba(230,0,34,0.4);
}
.banner.mood-turn {
  background: #e60022;
  color: #fafaf3;
  box-shadow: 6rpx 6rpx 0 #0a0a0a;
}
.banner.mood-wait {
  background: #0a0a0a;
  color: #ece5cf;
  border-color: #fafaf3;
  box-shadow: 4rpx 4rpx 0 rgba(230,0,34,0.4);
}
.banner.mood-end {
  background: #ffd200;
  color: #0a0a0a;
  border-color: #0a0a0a;
  box-shadow: 6rpx 6rpx 0 #e60022;
}

.inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  transform: skewX(9deg);
}
/* gap 替代 —— Skyline 1.4.7 flex+gap bug */
.inner > icon { margin: 0 12rpx; }

.text {
  font-size: 26rpx;
  letter-spacing: 0.16em;
  font-weight: 900;
  font-style: italic;
  white-space: nowrap;
}

/* 文本型 accent 例如 "1/2"：当一个 chip 单独挂尾巴 */
.chip {
  margin-left: 14rpx;
  padding: 2rpx 10rpx;
  background: rgba(0, 0, 0, 0.35);
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  display: inline-flex;
  align-items: center;
}
.chip text {
  font-size: 22rpx;
  font-weight: 900;
  font-style: italic;
  letter-spacing: 0.06em;
  white-space: nowrap;
}
