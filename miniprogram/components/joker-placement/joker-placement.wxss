.backdrop {
  position: fixed;
  inset: 0;
  background: rgba(10, 10, 10, 0.78);
  z-index: 95;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: p5-fade-in 0.22s ease-out;
}

.sheet {
  width: 100%;
  background: #131313;
  border-top: 5rpx solid #ffd200;
  padding: 28rpx 24rpx 56rpx;
  animation: joker-sheet-up 0.34s cubic-bezier(0.16, 1, 0.3, 1) backwards;
}

@keyframes joker-sheet-up {
  from { transform: translateY(110%); }
  to { transform: translateY(0); }
}

.subtitle {
  display: block;
  text-align: center;
  color: #ffd200;
  font-size: 22rpx;
  letter-spacing: 0.36em;
  font-weight: 800;
  font-style: italic;
}

.title {
  display: block;
  text-align: center;
  color: #fafaf3;
  font-size: 30rpx;
  letter-spacing: 0.08em;
  font-weight: 700;
  margin: 12rpx 0 22rpx;
}
.title .strong {
  color: #e60022;
  font-weight: 900;
  font-style: italic;
}

.preview {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.hand-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.slot {
  width: 54rpx;
  height: 144rpx;
  border: 3rpx dashed #e60022;
  background: rgba(230,0,34,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: skewX(-6deg);
}
.slot:active {
  background: #e60022;
}
.slot text {
  color: #e60022;
  font-size: 38rpx;
  font-weight: 900;
  font-style: italic;
  transform: skewX(6deg);
  display: inline-block;
}
.slot:active text { color: #fafaf3; }

.tile-wrap {
  display: inline-block;
  flex-shrink: 0;
}

.hint {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  color: rgba(250,250,243,0.55);
  font-size: 20rpx;
  letter-spacing: 0.24em;
  font-style: italic;
}
